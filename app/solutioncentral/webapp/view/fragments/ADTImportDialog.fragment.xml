<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:form="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:c="sap.ui.core">

	<Dialog showHeader="true" resizable="true" verticalScrolling="true" draggable="true" title="Import Packages" contentWidth="80rem" contentHeight="40rem" busyIndicatorDelay="0">
		<content>
			<MessageStrip showIcon="true" class="sapUiTinyMargin" type="Information" text="{i18n>msg.infoADTImport}"/>
			<Table id="idADTNodesTable" mode="MultiSelect"
				autoPopinMode="true"
				selectionChange=".onADTNodeSelectionChange"
				sticky="ColumnHeaders,HeaderToolbar" items="{ADTNodesModel>/nodes}">
				<headerToolbar>
					<OverflowToolbar>
						<Title text="{i18n>title.adtPackages} ({ADTNodesModel>/count})"/>
						<ToolbarSpacer/>
						<Button text="{i18n>button.viewSelected}" press=".onShowSelectedADT"/>
						<Button text="{i18n>button.viewAll}" press=".onShowAllADT"/>
						<SearchField width="20rem" search=".onADTNodesTableSearch" placeholder="{i18n>ph.adtSearchField}"/>
					</OverflowToolbar>
				</headerToolbar>
				<noData>
					<HBox justifyContent="Center">
						<Button text="{i18n>button.fetchPackages}" class="sapUiSmallMargin" icon="sap-icon://download" press=".onFetchADTPress"/>
					</HBox>
				</noData>
				<columns>
					<Column importance="High">
						<Text text="{i18n>column.adtName}"/>
					</Column>
					<Column importance="Low">
						<Text text="{i18n>column.adtDesc}"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{ADTNodesModel>ObjectName}"/>
							<Text text="{ADTNodesModel>Description}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Toolbar>
				<ToolbarSpacer/>
				<Button text="{i18n>button.import}" type="Emphasized" press=".onImportSolutionsPress" visible="{= ${ADTNodesModel>/count} > 0}"/>
				<Button text="{i18n>button.cancel}" press=".onCancelSolutionImport"/>
			</Toolbar>
		</footer>
	</Dialog>

</c:FragmentDefinition>
